{
  "name": "even-crypto",
  "version": "0.1.7",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc && vite build",
    "pack": "evenhub pack app.json dist -o even-crypto.ehpk",
    "simulator": "evenhub-simulator http://localhost:5173/ --automation-port 9898"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.10"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "^0.1.13",
    "@evenrealities/evenhub-simulator": "^0.7.3",
    "@types/node": "^24.10.1",
    "jsdom": "^27.2.0",
    "playwright": "^1.60.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.15"
  }
}
